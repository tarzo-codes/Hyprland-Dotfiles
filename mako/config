# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.
# Automatically generated by quickshell theme sync — do not hand-edit.

font=JetBrains Mono Nerd Font 11
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay
anchor=top-center
width=500
height=50
margin=5
padding=8,12,12
border-size=2
icons=1
max-icon-size=20
default-timeout=5000
ignore-timeout=1

# System Colors (synced from theme: melissa)
background-color=#202224dd
text-color=#F4EADB
border-color=#717070
border-radius=12

[urgency=normal]
border-color=#717070

[urgency=high]
border-color=#15242B
default-timeout=0

[app-name=lightcord]
border-color=#A29788

[summary~="log-.*"]
border-color=#46484A
