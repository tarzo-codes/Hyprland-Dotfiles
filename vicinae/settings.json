{
   "$schema": "https://vicinae.com/schemas/config.json",
   "wrap_navigation": true,
   "escape_key_behavior": "close_window",
   "font": {
      "family": "JetBrainsMono Nerd Font",
      "rendering": "native"
   },
   "theme": {
      "light": {
         "name": "custom",
         "icon_theme": "Tela-grey-dark"
      },
      "dark": {
         "name": "custom",
         "icon_theme": "Tela-grey-dark"
      }
   },
   "launcher_window": {
      "opacity": 0.95,
      "compact_mode": {
         "enabled": true
      }
   },
   "providers": {
      "theme": {
         "entrypoints": {
            "set": {
               "alias": "st"
            }
         }
      }
   }
}